{
  "name": "nuxt-meilisearch",
  "type": "module",
  "version": "1.5.1",
  "author": "Alex Duval",
  "license": "MIT",
  "homepage": "https://nuxt-meilisearch.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xlanex6/nuxt-meilisearch.git"
  },
  "contributors": [],
  "keywords": [
    "meilisearch",
    "search",
    "vue-instantsearch",
    "nuxt",
    "module"
  ],
  "exports": {
    ".": {
      "types": "./dist/types.d.ts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "release": "changelogen --release && pnpm publish && git push --follow-tags",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:ci": "pnpm dev:prepare && vitest run",
    "test:coverage": "vitest run --coverage",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit",
    "typecheck": "pnpm test:types",
    "clean": "rm -rf .nuxt .output node_modules pnpm-lock.yaml"
  },
  "dependencies": {
    "@meilisearch/instant-meilisearch": "0.31.2",
    "@nuxt/kit": "4.4.8",
    "instantsearch.css": "8.17.0",
    "meilisearch": "0.58.0",
    "vue-instantsearch": "4.26.8"
  },
  "devDependencies": {
    "@nuxt/devtools": "4.0.0-alpha.7",
    "@nuxt/eslint-config": "1.16.0",
    "@nuxt/module-builder": "1.0.2",
    "@nuxt/schema": "4.4.8",
    "@nuxt/test-utils": "4.0.3",
    "@nuxt/ui": "4.9.0",
    "@types/node": "25.9.3",
    "@vue/test-utils": "2.4.11",
    "changelogen": "0.6.2",
    "defu": "6.1.7",
    "eslint": "10.5.0",
    "happy-dom": "20.10.6",
    "nuxt": "4.4.8",
    "typescript": "latest",
    "vitest": "4.1.9",
    "vue-tsc": "3.3.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "directories": {
    "doc": "docs",
    "example": "playground"
  }
}
